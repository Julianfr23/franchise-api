# Example values - copy to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars with real credentials to Git

aws_region           = "us-east-1"
project_name         = "franchise-api"
environment          = "prod"
db_username          = "franchiseadmin"
db_password          = "CHANGE_ME_STRONG_PASSWORD"
docdb_instance_count = 1
docdb_instance_class = "db.t3.medium"
ecs_cpu              = "512"
ecs_memory           = "1024"
ecs_desired_count    = 1
